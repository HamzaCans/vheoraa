      </table>
      <div class="beden-ek">
        <h4>Diğer Ölçüler</h4>
        <div class="beden-ek-item">
          <div class="beden-ek-item-content"><strong>📿 Bileklik</strong><span>Standart: 16-18 cm, Uzun: 19-21 cm</span></div>
