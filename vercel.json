{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "*.html",
        "*.css",
        "app.js",
        "script.js",
        "cookie-consent.js",
        "maintenance.js",
        "favicon.png",
        "manifest.json",
        "sw.js",
        "images/**",
        "uploads/**",
        "admin/**",
        "*.jpg",
        "*.webp",
        "*.xml"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/admin*", "destination": "/api/index.js" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/", "destination": "/api/index.js" }
  ]
}
